# Bootstrap-only settings. Runtime config is stored in the DB (AppConfig table).

# API authentication token (sent as X-Api-Token header)
APP_API_TOKEN=dev-token

# SQLite database URL
DB_URL=sqlite:///./backend/app.db

# Bootstrap defaults (seeded into DB on first boot)
LMSTUDIO_BASE_URL=http://192.168.128.70:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=

# Server
HOST=0.0.0.0
PORT=8500
LOG_LEVEL=INFO
